@page "/management/integrations/google-reviews/auth"
@using Churchee.CQRS.Abstractions
@using Churchee.Module.Events.Features.Commands
@using Churchee.Module.Google.Reviews.Features.Commands
@using Microsoft.AspNetCore.Http
@using Microsoft.Extensions.Logging
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Sections
@using Radzen.Blazor
@using Radzen
@using Churchee.Common.Abstractions.Auth

<h1>Auth Redirect</h1>

@code {

    [Inject]
    private IHttpContextAccessor HttpContextAccessor { get; set; } = default!;

    [Inject]
    private ISender Mediator { get; set; } = default!;

    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;

    [SupplyParameterFromQuery]
    public string Code { get; set; }

    [SupplyParameterFromQuery]
    public string State { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var request = HttpContextAccessor.HttpContext.Request;

        await Mediator.Send(new EnableGoogleReviewsIntegrationCommand(Code, $"{request.Scheme}://{request.Host}"));

        HttpContextAccessor.HttpContext.Response.Redirect("/management/integrations/google-reviews");
    }
}
